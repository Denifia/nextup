{
  "name": "@denifia/nextup",
  "version": "1.6.0",
  "description": "CLI to resolve natural-language time expressions into concrete UTC minutes.",
  "license": "MIT",
  "type": "commonjs",
  "main": "dist/main.js",
  "bin": {
    "nextup": "dist/main.js"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Denifia/nextup.git"
  },
  "bugs": {
    "url": "https://github.com/Denifia/nextup/issues"
  },
  "homepage": "https://github.com/Denifia/nextup#readme",
  "keywords": [
    "cli",
    "time",
    "datetime",
    "natural-language",
    "timezone",
    "utc",
    "temporal",
    "chrono"
  ],
  "scripts": {
    "clean": "node -e \"const fs=require('node:fs'); for (const p of ['dist','coverage','.tsbuildinfo']) fs.rmSync(p,{recursive:true,force:true});\"",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/main.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "release:check": "npm run typecheck && npm test && npm run build && npm pack --dry-run",
    "release:notes": "node scripts/render-release-notes.mjs",
    "prepack": "npm run clean && npm run build"
  },
  "dependencies": {
    "@js-temporal/polyfill": "^0.5.1",
    "chrono-node": "^2.9.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "npm@11.10.1",
  "devDependencies": {
    "@types/node": "^25.5.2",
    "tsx": "^4.20.5",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
